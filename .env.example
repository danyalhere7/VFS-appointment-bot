# ─────────────────────────────────────────────────────────────
#  VFS Bot — Environment Variables Template
#  Copy this file to ".env" and fill in your real values.
#  NEVER commit your .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── VFS Global ────────────────────────────────────────────────
VFS_EMAIL=your_email@example.com
VFS_PASSWORD=your_password_here

# ── Telegram Notifications ────────────────────────────────────
# Create a bot via @BotFather on Telegram to get the token.
# Get your chat ID by messaging @userinfobot on Telegram.
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxYZ
TELEGRAM_CHAT_ID=123456789

# ── Email Notifications ───────────────────────────────────────
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECEIVER=receiver@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── CAPTCHA Solving (optional) ────────────────────────────────
# Leave blank to fall back to manual CAPTCHA solving via notification.
CAPTCHA_API_KEY=

# ── Bot Behaviour ─────────────────────────────────────────────
# Minimum and maximum delay (seconds) between checks
MIN_DELAY=180
MAX_DELAY=600

# Run browser in headless mode? (true/false)
# Set to false to reduce CAPTCHA triggers (recommended).
HEADLESS=false

# Comma-separated list of cities to monitor
CITIES=Islamabad,Lahore

# VFS service category
VFS_COUNTRY=Austria
VFS_SERVICE=Document Legalization
